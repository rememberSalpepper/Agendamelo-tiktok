# Copia este archivo como .env y rellena tus valores. El .env NO se sube al repo.
TELEGRAM_BOT_TOKEN=pon_aqui_el_token_de_botfather
TELEGRAM_CHAT_ID=tu_chat_id_numerico
AGENDAMELO_ALLOWED_CHATS=tu_chat_id_numerico

# Opcional — Codex (texto del LLM). Por defecto SIEMPRE usa lo más alto: modelo gpt-5.5 + esfuerzo
# xhigh. Solo define estas variables si quieres BAJARLO (p. ej. una tanda comparativa más barata).
# AGENDAMELO_CODEX_MODEL=gpt-5.5
# AGENDAMELO_CODEX_EFFORT controla `model_reasoning_effort`: minimal|low|medium|high|xhigh (default xhigh).
# OJO: xhigh NO garantiza mejor copy; el lever principal es el PROMPT.
# AGENDAMELO_CODEX_EFFORT=medium

# Opcional — datos y operación:
# AGENDAMELO_CSV=/ruta/absoluta/a/agendamelo_ideas.csv
# AGENDAMELO_SETTINGS=/ruta/absoluta/a/agendamelo_settings.json   # nicho activo + estilo de caption
